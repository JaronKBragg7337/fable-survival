# Public Supabase connection values are safe for browser code once RLS/grants are correct.
# The secret key must only live in Vercel environment variables or local untracked .env files.
VITE_SUPABASE_URL=https://ukguppzfpvdcemyxzdbn.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
SUPABASE_URL=https://ukguppzfpvdcemyxzdbn.supabase.co
SUPABASE_SECRET_KEY=sb_secret_your_server_only_key_here

# In-game AI chat (🤖 button) — server-only, see AI_CHAT.md. This endpoint can
# mutate live game state, so it is gated behind AI_CHAT_KEY on top of the API key.
ANTHROPIC_API_KEY=sk-ant-your_key_here
AI_CHAT_KEY=choose_a_private_code
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
